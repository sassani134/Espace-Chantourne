<%# app/views/static_pages/privacy_policy.html.erb %>

<div class="min-h-screen bg-gradient-to-b from-neutral-900 via-black to-neutral-900 py-16 sm:py-24">
  
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-green-500/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-12 text-center">
      <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 backdrop-blur-sm mb-6">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        <span class="text-xs font-mono tracking-[0.2em] text-neutral-400 uppercase">Privacy</span>
      </div>

      <h1 class="text-4xl font-black uppercase tracking-tight text-white sm:text-5xl md:text-6xl">
        Privacy
        <br />
        <span class="bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
          Policy
        </span>
      </h1>
      <p class="mt-4 text-sm text-neutral-400">
        Last updated: <%= Date.current.strftime("%B %d, %Y") %>
      </p>
    </div>

    <!-- Content -->
    <div class="space-y-8">
      
      <!-- Introduction -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <p class="text-sm leading-relaxed text-neutral-300">
          This Privacy Policy describes how <span class="text-green-400 font-medium">Espace-Chantourne</span> 
          ("we", "us", or "our") collects, uses, and shares information about you 
          when you visit our website <span class="text-white font-medium">espace-chantourne.com</span>.
        </p>
      </div>

      <!-- Information We Collect -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Information We Collect
        </h2>
        <div class="mt-4 space-y-3 text-sm text-neutral-300">
          <p>
            We use <span class="text-white font-medium">Google Analytics</span>, a web analytics service provided by 
            Google, Inc., to collect certain information relating to your use of the Site. 
            Google Analytics uses <span class="text-white">"cookies"</span>, which are text files placed on 
            your computer, to help the website analyze how users use the site.
          </p>
          <p class="text-xs text-neutral-400">
            The information generated by the cookie about your use of the website 
            (including your IP address) will be transmitted to and stored by Google on servers in the United States.
          </p>
        </div>
      </div>

      <!-- Anonymous Usage Statistics -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
          Anonymous Usage Statistics
        </h2>
        <div class="mt-4 space-y-3 text-sm text-neutral-300">
          <p>
            In addition to Google Analytics, we track <span class="text-white">anonymous usage statistics</span> 
            related to button clicks on certain features of the site. This helps us understand 
            which features are most popular and improve the user experience.
          </p>
          <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-4">
            <p class="text-xs text-neutral-400">
              <span class="font-medium text-green-400">🔒 No personal data collected:</span> 
              This tracking does not collect any personally identifiable information (PII). 
              A random anonymous session identifier is generated and stored in your browser. 
              Only the number of clicks per button and the count of unique anonymous users are recorded. 
              No names, email addresses, IP addresses, or other personal data are stored or associated with this usage data.
            </p>
            <p class="mt-2 text-xs text-neutral-500">
              💡 You may clear your browser's local storage at any time to reset your anonymous session identifier.
            </p>
          </div>
        </div>
      </div>

      <!-- How We Use Information -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          How We Use Information
        </h2>
        <div class="mt-4 space-y-3 text-sm text-neutral-300">
          <p>
            We use the information collected through Google Analytics to:
          </p>
          <ul class="ml-6 space-y-1 list-disc text-sm text-neutral-300">
            <li>Analyze trends</li>
            <li>Administer the site</li>
            <li>Track users' movements around the site</li>
            <li>Gather demographic information about our user base as a whole</li>
          </ul>
          <p class="text-xs text-neutral-400">
            Google may use this information for the purpose of evaluating your use of the website, 
            compiling reports on website activity for website operators and providing other services 
            relating to website activity and internet usage.
          </p>
        </div>
      </div>

      <!-- Third-Party Disclosure -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
          </svg>
          Third-Party Disclosure
        </p>
        <p class="mt-4 text-sm text-neutral-300">
          Google may transfer this information to third parties where required to do so by law, 
          or where such third parties process the information on Google's behalf.
        </p>
      </div>

      <!-- Your Rights and Choices -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Your Rights and Choices
        </p>
        <div class="mt-4 space-y-3 text-sm text-neutral-300">
          <p>
            You can prevent Google from recognizing you on return visits to this site by 
            <span class="text-white">disabling cookies</span> in your browser.
          </p>
          <p>
            You can also opt-out of Google Analytics by installing 
            the Google Analytics Opt-out Browser Add-on available at:
          </p>
          <div class="mt-2">
            <%= link_to "https://tools.google.com/dlpage/gaoptout", 
                target: "_blank", 
                rel: "noopener noreferrer", 
                class: "inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-2 text-xs text-neutral-300 transition hover:bg-white/10 hover:text-white border border-white/10 hover:border-green-500/30" do %>
              <svg class="h-4 w-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Google Analytics Opt-out
            <% end %>
          </div>
        </div>
      </div>

      <!-- Changes to This Privacy Policy -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Changes to This Privacy Policy
        </p>
        <p class="mt-4 text-sm text-neutral-300">
          We may update this Privacy Policy from time to time. 
          We will notify you of any changes by posting the new Privacy Policy on this page. 
          You are advised to review this Privacy Policy periodically for any changes.
        </p>
      </div>

      <!-- Contact Us -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-green-500/30 hover:bg-white/10 md:p-8">
        <h2 class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Contact Us
        </p>
        <div class="mt-4 space-y-2 text-sm text-neutral-300">
          <p>If you have any questions about this Privacy Policy, please contact us:</p>
          <div class="mt-3 rounded-lg border border-green-500/20 bg-green-500/5 p-4">
            <p class="text-sm text-neutral-300">
              <span class="font-medium text-green-400">📧 Email:</span><br />
              <%= link_to "espace.chantourne@proton.me", 
                  "mailto:espace.chantourne@proton.me", 
                  class: "text-green-400 hover:text-green-300 transition underline-offset-2 hover:underline font-mono text-sm" %>
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-12 text-center">
        <div class="h-px w-24 mx-auto bg-gradient-to-r from-transparent via-green-500/20 to-transparent"></div>
        <p class="mt-6 text-xs text-neutral-500">
          &copy; <%= Date.current.year %> <span class="text-green-400">Espace-Chantourne</span> — All rights reserved
        </p>
      </div>
    </div>
  </div>
</div>