<!-- Version plus narrative avec une timeline -->
<section class="relative min-h-[100dvh] w-full overflow-hidden bg-gradient-to-b from-neutral-900 via-black to-neutral-900">
  
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-green-500/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-[100dvh] max-w-7xl flex-col items-center justify-center gap-12 px-6 md:flex-row md:gap-16 lg:px-12">
    
    <!-- Left: Logo -->
    <div class="flex w-full max-w-sm flex-shrink-0 items-center justify-center md:w-1/2 md:justify-end">
      <%= link_to root_path, class: "block transition-transform hover:scale-105 duration-300" do %>
        <%= image_tag "EcTextLogoNoBg.png", alt: "Espace Chantourne", class: "h-40 w-auto md:h-56 lg:h-72" %>
      <% end %>
    </div>

    <!-- Right: Content -->
    <div class="flex w-full flex-col items-center text-center md:w-1/2 md:items-start md:text-left">


      <!-- Main Title -->
      <h1 class="text-3xl font-black uppercase tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl">
        What is
        <br />
        <span class="bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
          Espace-Chantourne?
        </span>
      </h1>

      <!-- Description with the pirate theme -->
      <div class="mt-6 max-w-2xl space-y-4">
        <p class="text-base leading-relaxed text-neutral-300 sm:text-lg">
          <span class="text-green-400 font-medium">Indie studio</span> based near 
          <span class="text-white">Grenoble, France</span>.
          <br class="hidden sm:block" />
          <span class="text-sm text-neutral-400">For now I'm a solo dev but maybe someday the Pirate King will create his crew. 🏴‍☠️</span>
        </p>
        
        <p class="text-sm leading-relaxed text-neutral-400 sm:text-base">
          We craft <span class="text-white">high-quality</span> and 
          <span class="text-white">light-hearted</span> games that bring joy to players.
          <br />
          Also, I build <span class="text-green-400">custom websites</span> for companies and creators.
        </p>

        <!-- Quote block -->
        <div class="relative mt-4 rounded-lg border-l-2 border-green-500/50 bg-white/5 p-4 pl-6 backdrop-blur-sm">
          <svg class="absolute -left-2 -top-2 h-6 w-6 text-green-500/30" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-sm italic text-neutral-300">
            "I started <span class="text-green-400">Espace-Chantourne</span> in 
            <span class="text-white font-medium">2026</span> with a simple goal: 
            <span class="text-green-400">sharing my passion</span> with the world."
          </p>
          <p class="mt-1 text-xs text-neutral-500">— The Pirate King (in training)</p>
        </div>
      </div>

      <!-- What we do -->
      <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500/10">
            <svg class="h-4 w-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <span class="text-sm text-neutral-300">Game Development</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500/10">
            <svg class="h-4 w-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <span class="text-sm text-neutral-300">Web Design</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500/10">
            <svg class="h-4 w-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <span class="text-sm text-neutral-300">3D & Animation</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500/10">
            <svg class="h-4 w-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
            </svg>
          </div>
          <span class="text-sm text-neutral-300">Light-hearted Games</span>
        </div>
      </div>

      <!-- CTA -->
      <!--
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <%= link_to "#", class: "group inline-flex items-center gap-3 rounded-full bg-gradient-to-r from-green-600 to-emerald-600 px-8 py-4 text-sm font-medium text-white transition-all hover:scale-105 hover:shadow-xl hover:shadow-green-500/25" do %>
          <span>Join the adventure</span>
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        <% end %>
        <%#= link_to "#", class: "text-sm text-neutral-400 transition hover:text-white" do %>
          Learn more →
        <%# end %>
      </div>
    </div>
  </div>
  -->


</section>