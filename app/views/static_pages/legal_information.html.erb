<%# app/views/static_pages/legal.html.erb %>

<div class="min-h-screen bg-gradient-to-b from-neutral-900 to-black py-16 pt-32 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-black uppercase tracking-tight text-white sm:text-5xl md:text-6xl">
        Legal
        <br />
        <span class="bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
          Notices
        </span>
      </h1>
    </div>

    <!-- Content -->
    <div class="space-y-6 divide-y divide-white/5">
      
      <!-- Publisher -->
      <div class="py-6">
        <h2 class="text-lg font-bold text-white">Publisher Information</h2>
        <div class="mt-3 space-y-1 text-sm text-neutral-400">
          <p><span class="text-white">Publisher:</span> Espace-Chantourne</p>
          <p><span class="text-white">Headquarters:</span> Grenoble, Isère, France</p>
          <p><span class="text-white">Development:</span> Espace-Chantourne</p>
          <p><span class="text-white">Technology:</span> Ruby on Rails</p>
        </div>
      </div>

      <!-- Hosting -->
      <div class="py-6">
        <h2 class="text-lg font-bold text-white">Hosting</h2>
        <div class="mt-3 space-y-1 text-sm text-neutral-400">
          <p><span class="text-white">Hosting Provider:</span> DigitalOcean, Inc.</p>
          <p class="text-xs">
            <%= link_to "https://m.do.co/c/2748e0b9c0cd", "https://m.do.co/c/2748e0b9c0cd", target: "_blank", rel: "noopener noreferrer", class: "text-green-400 hover:text-green-300" %>
          </p>
        </div>
        <a href="https://www.digitalocean.com/?refcode=2748e0b9c0cd&utm_campaign=Referral_Invite&utm_medium=Referral_Program&utm_source=badge">
          <img src="https://web-platforms.sfo2.cdn.digitaloceanspaces.com/WWW/Badge%201.svg" alt="DigitalOcean Referral Badge" />
        </a>
      </div>

      <!-- Personal Data -->
      <div class="py-6">
        <h2 class="text-lg font-bold text-white">Personal Data</h2>
        <div class="mt-3 space-y-2 text-sm text-neutral-400">
          <p>Compliant with <span class="text-white">GDPR</span> and French data protection laws.</p>
          <p>Data is retained for a maximum of <span class="text-white">3 months</span>.</p>
          <p class="text-xs text-neutral-500">DPO Contact: <%= mail_to "espace.chantourne@proton.me", "espace.chantourne@proton.me", class: "text-green-400 hover:text-green-300" %></p>
        </div>
      </div>

      <!-- Cookies -->
      <div class="py-6">
        <h2 class="text-lg font-bold text-white">Cookies</h2>
        <div class="mt-3 space-y-2 text-sm text-neutral-400">
          <p>Cookies are used to analyze site traffic and improve user experience.</p>
          <p class="text-xs text-neutral-500">Consent valid for <span class="text-white">13 months</span>.</p>
          <%= link_to "Configure cookies", "https://www.cnil.fr/fr/cookies-les-outils-pour-les-maitriser", target: "_blank", rel: "noopener noreferrer", class: "text-xs text-green-400 hover:text-green-300" %>
        </div>
      </div>

      <!-- Footer -->
      <div class="py-6 text-center text-xs text-neutral-500">
        <p>&copy; <%= Date.current.year %> Espace-Chantourne — All rights reserved</p>
      </div>
    </div>
  </div>
</div>