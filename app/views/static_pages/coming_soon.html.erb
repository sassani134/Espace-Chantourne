<%# app/views/static_pages/coming_soon.html.erb %>

<!-- Coming Soon Page -->
<section class="relative flex min-h-[100dvh] w-full items-center justify-center overflow-hidden bg-gradient-to-b from-neutral-900 via-black to-neutral-900">
  
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-green-500/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-green-500/5 blur-3xl"></div>
  </div>

  <!-- Animated particles (optional) -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute h-2 w-2 rounded-full bg-green-400/20 animate-pulse" style="top: 10%; left: 20%; animation-delay: 0s;"></div>
    <div class="absolute h-3 w-3 rounded-full bg-emerald-400/20 animate-pulse" style="top: 30%; right: 15%; animation-delay: 0.5s;"></div>
    <div class="absolute h-2 w-2 rounded-full bg-green-400/20 animate-pulse" style="bottom: 25%; left: 10%; animation-delay: 1s;"></div>
    <div class="absolute h-3 w-3 rounded-full bg-emerald-400/20 animate-pulse" style="bottom: 15%; right: 20%; animation-delay: 1.5s;"></div>
    <div class="absolute h-2 w-2 rounded-full bg-green-400/20 animate-pulse" style="top: 50%; left: 5%; animation-delay: 0.8s;"></div>
    <div class="absolute h-2 w-2 rounded-full bg-emerald-400/20 animate-pulse" style="top: 60%; right: 5%; animation-delay: 1.2s;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center px-6 text-center">
    
    <!-- Logo -->
    <div class="mb-8">
      <%= link_to root_path, class: "block transition-transform hover:scale-105 duration-300" do %>
        <%= image_tag "EcTextLogoNoBg.png", alt: "Espace Chantourne", class: "h-32 w-auto md:h-40 lg:h-48" %>
      <% end %>
    </div>



    <!-- Main Title -->
    <h1 class="text-5xl font-black uppercase tracking-tight text-white sm:text-6xl md:text-7xl lg:text-8xl">
      Coming
      <br />
      <span class="bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
        Soon
      </span>
    </h1>

    <!-- Description -->
  <p class="mt-6 max-w-md text-base leading-relaxed text-neutral-400 sm:text-lg md:max-w-lg">
    We're preparing something exceptional for you.
    <br />
    <span class="text-sm text-neutral-500">Stay tuned, the adventure begins soon!</span>
  </p>

    <!-- Countdown Timer (optionnel) 
