<%# /app/views/partials/_modal_don.html.erb%>
<%# locals: (title:, platform:, logo:,  input_value:) -%>


<!-- Modal avec texte personnalisable -->
<div data-controller="modal" class="flex flex-col">
  <!-- Bouton d'ouverture -->
  <button data-action="modal#show" 
          class="group flex flex-col items-center justify-center gap-3 p-6 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl transition-all hover:bg-white/10 hover:border-green-500/50 hover:scale-105 hover:shadow-xl hover:shadow-green-500/10">
    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#0070BA] to-[#003087] flex items-center justify-center text-white text-2xl font-bold transition-transform group-hover:scale-110">
      <%= local_assigns[:logo] %>
    </div>
    <span class="text-sm font-medium text-white"><%= local_assigns[:title] || "PayPal" %></span>
    <span class="text-xs text-neutral-500"><%= local_assigns[:platform] || "EUR" %></span>
  </button>

  <!-- Dialog Modal -->
  <dialog data-modal-target="dialog" 
          class="p-0 rounded-2xl backdrop:bg-black/80 backdrop:backdrop-blur-sm w-full max-w-lg mx-auto bg-transparent z-50">
    
    <div class="bg-gradient-to-b from-neutral-900 to-black rounded-2xl border border-white/10 shadow-2xl shadow-green-500/5 overflow-hidden">
      <!-- Modal Header -->
      <div class="px-6 py-5 border-b border-white/10 flex items-center justify-between">
        <h3 class="text-xl font-bold text-white">Share Content</h3>
        <button data-action="modal#close" 
                class="p-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6 space-y-6 z-50">
        <!-- Texte d'information -->
        <p class="text-sm text-neutral-400 leading-relaxed">
          Copy the text below to your clipboard. You can use it anywhere you need.
        </p>

        <!-- Zone de texte avec Clipboard -->
        <div data-controller="clipboard" 
             data-clipboard-success-content-value="Copied!">
          
          <div class="relative">
            <input type="text" 
                   value="<%= local_assigns[:input_value] || 'Click the button to copy me!' %>" 
                   data-clipboard-target="source" 
                   class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-transparent transition-all pr-12" />
            
            <!-- Indicateur de statut -->
            <div data-clipboard-target="status" 
                 class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-medium text-green-400 opacity-0 transition-opacity">
              Copied!
            </div>
          </div>

          <!-- Boutons d'action -->
          <div class="flex flex-wrap gap-3 mt-4">
            <button type="button" 
                    data-action="clipboard#copy" 
                    data-clipboard-target="button" 
                    class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 text-white text-sm font-medium rounded-xl transition-all hover:scale-105 hover:shadow-lg hover:shadow-green-500/25">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <span>Copy to Clipboard</span>
            </button>
            
            <button type="button" 
                    data-action="modal#close" 
                    class="px-6 py-2.5 border border-white/10 text-neutral-400 text-sm font-medium rounded-xl hover:bg-white/5 hover:text-white transition-colors">
              Close
            </button>
          </div>
        </div>

        <!-- Message de confirmation supplémentaire -->
        <div class="flex items-center gap-3 p-4 bg-green-500/5 border border-green-500/20 rounded-xl">
          <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-xs text-neutral-400">
            <span class="text-green-400 font-medium">Tip:</span> The text will be copied to your clipboard. You can paste it anywhere using <kbd class="px-1.5 py-0.5 bg-white/5 border border-white/10 rounded text-[10px] font-mono">Ctrl+V</kbd> (or <kbd class="px-1.5 py-0.5 bg-white/5 border border-white/10 rounded text-[10px] font-mono">Cmd+V</kbd> on Mac).
          </p>
        </div>
      </div>

      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-white/5 bg-white/5">
        <p class="text-[10px] text-neutral-500 font-mono tracking-wider text-center">
          &copy; 2026 Espace Chantourne — All rights reserved
        </p>
      </div>
    </div>
  </dialog>
</div>
