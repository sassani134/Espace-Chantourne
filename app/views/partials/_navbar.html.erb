<%# app/views/layouts/_navbar.html.erb %>

<header class="fixed left-0 right-0 top-0 z-50 mx-4 my-4 rounded-2xl bg-gradient-to-r from-green-600 to-emerald-600 shadow-lg dark:from-green-700 dark:to-emerald-700">
  <div class="mx-auto flex h-20 max-w-7xl items-center gap-8 px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <%= link_to root_path, class: "block flex-shrink-0" do %>
      <%= image_tag "EcTextLogoNoBg.png", alt: "Espace Chantourne Logo", class: "h-32 w-auto transition hover:opacity-80 md:h-32" %>
    <% end %>

    <!-- Navigation -->
    <div class="flex flex-1 items-center justify-end md:justify-between">
      <nav aria-label="Global" class="hidden md:block">
        <ul class="flex items-center gap-6 text-sm font-medium">
          <li><%= link_to "About", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
          <li><%= link_to "Careers", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
          <li><%= link_to "History", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
          <li><%= link_to "Services", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
          <li><%= link_to "Projects", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
          <li><%= link_to "Blog", "#", class: "text-white/90 transition hover:text-white dark:text-green-200 dark:hover:text-white" %></li>
        </ul>
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-4">

        <!-- Mobile Menu Button -->
        <button
          class="block rounded-md bg-white/20 p-2.5 text-white transition hover:bg-white/30 md:hidden dark:bg-green-800/40 dark:hover:bg-green-800/60"
          data-controller="mobile-menu"
          data-action="click->mobile-menu#toggle"
        >
          <span class="sr-only">Toggle menu</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
