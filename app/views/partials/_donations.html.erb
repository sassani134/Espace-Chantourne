<!-- Donation Section -->
<section class="relative w-full bg-gradient-to-b from-black to-neutral-900 py-24 md:py-32 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 bg-green-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-emerald-500 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
    <!-- Header -->
    <div class="text-center mb-16">

      <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-6">
        Make a
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">
          Donation
        </span>
      </h2>
      
      <p class="text-neutral-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Donations help me cover infrastructure costs and supplement my 9-to-5 job.
        Every contribution, no matter the size, is deeply appreciated.
      </p>
    </div>

    <!-- Donation Methods Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">


      <!-- Ko-fi -->
      <%= link_to "https://ko-fi.com/G2G11CTJFX",
          target: "_blank",
          rel: "noopener noreferrer",
          class: "group flex flex-col items-center justify-center gap-3 p-6 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl transition-all hover:bg-white/10 hover:border-green-500/50 hover:scale-105 hover:shadow-xl hover:shadow-green-500/10" do %>

        <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#FF5E5B] to-[#FF8A80] flex items-center justify-center text-white text-2xl font-bold transition-transform group-hover:scale-110">
          <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.351 2.715c-2.7 0-4.986.025-6.83.26C2.078 3.285 0 5.154 0 8.61c0 3.506.182 6.13 1.585 8.493 1.584 2.701 4.233 4.182 7.662 4.182h.83c4.209 0 6.494-2.234 7.637-4a9.5 9.5 0 0 0 1.091-2.338C21.792 14.688 24 12.22 24 9.208v-.415c0-3.247-2.13-5.507-5.792-5.87-1.558-.156-2.65-.208-6.857-.208m0 1.947c4.208 0 5.09.052 6.571.182 2.624.311 4.13 1.584 4.13 4v.39c0 2.156-1.792 3.844-3.87 3.844h-.935l-.156.649c-.208 1.013-.597 1.818-1.039 2.546-.909 1.428-2.545 3.064-5.922 3.064h-.805c-2.571 0-4.831-.883-6.078-3.195-1.09-2-1.298-4.155-1.298-7.506 0-2.181.857-3.402 3.012-3.714 1.533-.233 3.559-.26 6.39-.26m6.547 2.287c-.416 0-.65.234-.65.546v2.935c0 .311.234.545.65.545 1.324 0 2.051-.754 2.051-2s-.727-2.026-2.052-2.026m-10.39.182c-1.818 0-3.013 1.48-3.013 3.142 0 1.533.858 2.857 1.949 3.897.727.701 1.87 1.429 2.649 1.896a1.47 1.47 0 0 0 1.507 0c.78-.467 1.922-1.195 2.623-1.896 1.117-1.039 1.974-2.364 1.974-3.897 0-1.662-1.247-3.142-3.039-3.142-1.065 0-1.792.545-2.338 1.298-.493-.753-1.246-1.298-2.312-1.298"/>
