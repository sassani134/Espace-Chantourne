<div class="min-h-screen bg-black text-white font-sans overflow-x-hidden">
  <!-- Video Hero Section -->
  <section class="relative h-[100svh] w-full flex items-center justify-center overflow-hidden">
    <!-- Desktop Video -->
    <div class="hidden md:block absolute top-0 left-0 w-full h-full z-0 pointer-events-none">
      <%= video_tag "kayKitPlatReady.mp4", 
                    autoplay: true, loop: true, muted: true, playsinline: true, 
                    class: "w-full h-full object-cover opacity-60" %>
    </div>
    
    <!-- Mobile Video -->
    <div class="block md:hidden absolute top-0 left-0 w-full h-full z-0 pointer-events-none">
      <%= video_tag "KaykitInsta.mp4", 
                    autoplay: true, loop: true, muted: true, playsinline: true, 
                    class: "w-full h-full object-cover opacity-60" %>
    </div>

    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black z-1"></div>

    <div class="relative z-10 text-center px-6">
      <h1 class="text-6xl md:text-9xl font-black uppercase tracking-tight mb-4 animate-in fade-in slide-in-from-bottom-8 duration-1000">
        Espace <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">Chantourne</span>
      </h1>
      <div class="h-1 w-24 bg-white mx-auto mb-6"></div>
      <p class="text-lg md:text-2xl font-light tracking-[0.4em] text-neutral-300 uppercase animate-in fade-in duration-1000 delay-500">
        Games - Web
      </p>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-bold mb-2">Scroll Down</span>
      <div class="w-[2px] h-12 bg-gradient-to-b from-white to-transparent"></div>
    </div>
  </section>


<!-- Three.js Section -->
<section class="relative h-[100svh] w-full bg-black overflow-hidden" 
         data-controller="threejs" 
         data-threejs-model-path-value="<%= "model3D/sophia.glb" %>">
    
    <!-- ThreeJS Canvas Container - Réduit pour laisser plus de place au texte -->
    <div data-threejs-target="canvas" class="absolute right-0 top-0 w-[55%] h-full z-0">
      <!-- Le canvas remplira cette zone -->
    </div>

    <!-- Overlay gradient pour fondre le modèle -->
    <div class="absolute right-0 top-0 w-[55%] h-full z-1 pointer-events-none bg-gradient-to-l from-transparent via-transparent to-neutral-900/80"></div>

    <!-- Contenu textuel à gauche - PREND PLUS DE PLACE -->
    <div class="relative z-10 h-full flex items-center px-8 md:px-16 lg:px-24 w-full md:w-[60%]">
      <div class="space-y-8 md:space-y-10 max-w-3xl">


        <!-- Titre principal - PLUS GRAND -->
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-[0.85]">
          Games &
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 via-emerald-400 to-green-500">
            Web
          </span>
        </h1>

        <!-- Sous-titre - PLUS LARGE -->
        <p class="text-xl md:text-2xl lg:text-3xl text-neutral-400 max-w-2xl leading-relaxed font-light">
          Crafting games with heart. 
          <br>
          Building websites with soul.
          <br>
          Just want to make cool stuff to share with others
        </p>

        <!-- Séparateur décoratif -->
        <div class="w-24 h-0.5 bg-gradient-to-r from-green-500 to-emerald-500"></div>



      </div>
    </div>


  </section>




<!-- Projects Section -->
<section class="relative w-full bg-black py-24 md:py-32 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-0 w-96 h-96 bg-green-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-emerald-500 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
    <!-- Header -->
    <div class="text-center mb-16">


      <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-6">
        Our
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">
          Projects
        </span>
      </h2>
      
      <p class="text-neutral-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Discover our latest creations and collaborations. Each project is crafted with passion and precision.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      <!-- Card 1 - Left (Smaller) -->
      <a href="https://github.com/sassani134/pokemmoDex01" class="group relative block bg-black rounded-2xl overflow-hidden shadow-xl transition-all hover:shadow-2xl hover:shadow-green-500/10 hover:-translate-y-1">
        <%= image_tag "Pokedex_Pokemmo.webp", alt: "Espace Chantourne Logo", class: "absolute inset-0 h-full w-full object-cover opacity-75 transition-opacity group-hover:opacity-50" %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <div class="relative p-6 md:p-8 h-[400px] md:h-[450px] flex flex-col justify-end">
          <h3 class="text-2xl font-bold text-white mb-2">PokemmoDex</h3>
          <p class="text-sm text-neutral-300 line-clamp-2">A modern web application built with Rails and Hotwire.</p>

          <div class="mt-6 translate-y-4 transform opacity-0 transition-all group-hover:translate-y-0 group-hover:opacity-100">
            <div class="flex items-center gap-3 text-sm text-green-400">
              <span>View Project</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 2 - Center (LARGER) -->
      <a href="https://github.com/sassani134/TheOpenSourceBrigade" class="group relative block bg-black rounded-2xl overflow-hidden shadow-xl transition-all hover:shadow-2xl hover:shadow-green-500/20 hover:-translate-y-1 md:scale-105 md:z-10">
        <%= image_tag "tosb.webp", alt: "Espace Chantourne Logo", class: "absolute inset-0 h-full w-full object-cover opacity-75 transition-opacity group-hover:opacity-50" %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <!-- Featured badge -->
        <div class="absolute top-4 right-4 z-10">
          <span class="bg-gradient-to-r from-green-500 to-emerald-500 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
            Featured
          </span>
        </div>

        <div class="relative p-6 md:p-10 h-[450px] md:h-[550px] flex flex-col justify-end">
          <h3 class="text-3xl md:text-4xl font-bold text-white mb-2">The Open Source Brigade</h3>
          <p class="text-sm md:text-base text-neutral-300 line-clamp-3 max-w-md">
            The Open Source Brigade is a 3d platformer game made with Godot.
          </p>



          <div class="mt-6 translate-y-4 transform opacity-0 transition-all group-hover:translate-y-0 group-hover:opacity-100">
            <div class="flex items-center gap-3 text-sm text-green-400 font-medium">
              <span>View Project</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 3 - Right (Smaller) -->
      <a href="https://github.com/sassani134/KayKit-Platformer-Pack-Godot-Ready" class="group relative block bg-black rounded-2xl overflow-hidden shadow-xl transition-all hover:shadow-2xl hover:shadow-green-500/10 hover:-translate-y-1">
        <%= image_tag "GodotReadyTampon.webp", alt: "Espace Chantourne Logo", class: "absolute inset-0 h-full w-full object-cover opacity-75 transition-opacity group-hover:opacity-50" %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <div class="relative p-6 md:p-8 h-[400px] md:h-[450px] flex flex-col justify-end">

          <h3 class="text-2xl font-bold text-white mb-2">Godot Ready series</h3>
          <p class="text-sm text-neutral-300 line-clamp-2">a series of simple plugins with 3d assets</p>

          <div class="mt-6 translate-y-4 transform opacity-0 transition-all group-hover:translate-y-0 group-hover:opacity-100">
            <div class="flex items-center gap-3 text-sm text-green-400">
              <span>View Project</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </a>
    </div>

    <!-- CTA Button -->
    <!-- coming soon -->
    <div class="text-center mt-16">
    <%= link_to coming_soon_path, class: "group inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-green-600 to-emerald-600 rounded-full text-white font-medium text-lg transition-all hover:scale-105 hover:shadow-2xl hover:shadow-green-500/30" do %>
      <span>View All Projects</span>
      <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    <% end %>
      <p class="text-neutral-500 text-sm mt-4">Explore our complete portfolio of innovative solutions</p>
    </div>
  </div>
</section>


<%= render partial: 'partials/donations' %>



    <!-- Footer message 
    <div class="text-center mt-16">
      <div class="inline-flex items-center gap-3 text-sm text-neutral-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
