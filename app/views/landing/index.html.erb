        <div class="absolute top-4 right-4 z-10">
          <span class="bg-gradient-to-r from-green-500 to-emerald-500 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
            Featured
          </span>
        </div>

        <div class="relative p-6 md:p-10 h-[450px] md:h-[550px] flex flex-col justify-end">
          <div class="mb-2">
            <span class="text-xs font-mono tracking-widest text-green-400 uppercase bg-black/50 px-3 py-1 rounded-full">Full Stack</span>
          </div>
          <h3 class="text-3xl md:text-4xl font-bold text-white mb-2">Espace Platform</h3>
          <p class="text-sm md:text-base text-neutral-300 line-clamp-3 max-w-md">
            A comprehensive digital ecosystem combining 3D experiences, community features, and real-time collaboration tools.
          </p>

          <div class="flex flex-wrap gap-2 mt-4">
            <span class="text-[10px] font-mono text-neutral-400 bg-white/5 px-2 py-1 rounded">Rails 8</span>
            <span class="text-[10px] font-mono text-neutral-400 bg-white/5 px-2 py-1 rounded">Three.js</span>
            <span class="text-[10px] font-mono text-neutral-400 bg-white/5 px-2 py-1 rounded">Tailwind</span>
            <span class="text-[10px] font-mono text-neutral-400 bg-white/5 px-2 py-1 rounded">Stimulus</span>
          </div>

          <div class="mt-6 translate-y-4 transform opacity-0 transition-all group-hover:translate-y-0 group-hover:opacity-100">
            <div class="flex items-center gap-3 text-sm text-green-400 font-medium">
              <span>View Project</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Card 3 - Right (Smaller) -->
      <a href="#" class="group relative block bg-black rounded-2xl overflow-hidden shadow-xl transition-all hover:shadow-2xl hover:shadow-green-500/10 hover:-translate-y-1">
        <img
          alt="Project 3"
          src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=1170"
          class="absolute inset-0 h-full w-full object-cover opacity-75 transition-opacity group-hover:opacity-50"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <div class="relative p-6 md:p-8 h-[400px] md:h-[450px] flex flex-col justify-end">
          <div class="mb-2">
            <span class="text-xs font-mono tracking-widest text-green-400 uppercase bg-black/50 px-3 py-1 rounded-full">Mobile</span>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Project Gamma</h3>
