<div class="min-h-screen bg-black text-white font-sans overflow-x-hidden">
  <!-- Video Hero Section -->
  <section class="relative h-[100svh] w-full flex items-center justify-center overflow-hidden">
    <!-- Desktop Video -->
    <div class="hidden md:block absolute top-0 left-0 w-full h-full z-0 pointer-events-none">
      <%= video_tag "kayKitPlatReady.mp4", 
                    autoplay: true, loop: true, muted: true, playsinline: true, 
                    class: "w-full h-full object-cover opacity-60" %>
    </div>
    
    <!-- Mobile Video -->
    <div class="block md:hidden absolute top-0 left-0 w-full h-full z-0 pointer-events-none">
      <%= video_tag "KaykitInsta.mp4", 
                    autoplay: true, loop: true, muted: true, playsinline: true, 
                    class: "w-full h-full object-cover opacity-60" %>
    </div>

    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black z-1"></div>

    <div class="relative z-10 text-center px-6">
      <h1 class="text-6xl md:text-9xl font-black uppercase tracking-tight mb-4 animate-in fade-in slide-in-from-bottom-8 duration-1000">
        Espace <span class="text-neutral-500">Chantourne</span>
      </h1>
      <div class="h-1 w-24 bg-white mx-auto mb-6"></div>
      <p class="text-lg md:text-2xl font-light tracking-[0.4em] text-neutral-300 uppercase animate-in fade-in duration-1000 delay-500">
        Digital Exploration
      </p>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-bold mb-2">Scroll Down</span>
      <div class="w-[2px] h-12 bg-gradient-to-b from-white to-transparent"></div>
    </div>
  </section>


<!-- Three.js Section -->
<section class="relative h-[100svh] w-full bg-gradient-to-b from-neutral-900 to-black overflow-hidden" 
         data-controller="threejs" 
         data-threejs-model-path-value="<%= "/model3D/godot_plush/godot_plush_model.glb" %>">
    
    <!-- ThreeJS Canvas Container - Réduit pour laisser plus de place au texte -->
    <div data-threejs-target="canvas" class="absolute right-0 top-0 w-[55%] h-full z-0">
      <!-- Le canvas remplira cette zone -->
    </div>

    <!-- Overlay gradient pour fondre le modèle -->
    <div class="absolute right-0 top-0 w-[55%] h-full z-1 pointer-events-none bg-gradient-to-l from-transparent via-transparent to-neutral-900/80"></div>

    <!-- Contenu textuel à gauche - PREND PLUS DE PLACE -->
    <div class="relative z-10 h-full flex items-center px-8 md:px-16 lg:px-24 w-full md:w-[60%]">
      <div class="space-y-8 md:space-y-10 max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-3 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full px-5 py-2.5">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
          </span>
          <span class="text-xs font-mono tracking-[0.2em] text-neutral-400 uppercase">3D Interactive Experience</span>
        </div>

        <!-- Titre principal - PLUS GRAND -->
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-[0.85]">
          Godot
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 via-emerald-400 to-green-500">
            Plush
          </span>
        </h1>

        <!-- Sous-titre - PLUS LARGE -->
        <p class="text-xl md:text-2xl lg:text-3xl text-neutral-400 max-w-2xl leading-relaxed font-light">
          Experience the beloved Godot Engine mascot in full 3D. 
          A continuous 360° rotation showcasing every detail of this 
          iconic plush character.
        </p>

        <!-- Séparateur décoratif -->
        <div class="w-24 h-0.5 bg-gradient-to-r from-green-500 to-emerald-500"></div>

        <!-- Informations techniques - PLUS ESPACÉES -->
        <div class="flex flex-wrap gap-12 text-sm">
          <div>
            <span class="block text-neutral-600 font-mono text-[11px] uppercase tracking-wider">Model</span>
            <span class="text-white text-lg font-medium">Godot Plush v1.0</span>
          </div>
          <div>
            <span class="block text-neutral-600 font-mono text-[11px] uppercase tracking-wider">Format</span>
            <span class="text-white text-lg font-medium">GLB / Three.js</span>
          </div>
          <div>
            <span class="block text-neutral-600 font-mono text-[11px] uppercase tracking-wider">Rotation</span>
            <span class="text-white text-lg font-medium">360° Auto</span>
          </div>
        </div>

        <!-- Call to action - PLUS GRANDS BOUTONS -->
        <div class="flex flex-wrap gap-4 pt-6">
          <a href="#" class="group inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-green-600 to-emerald-600 rounded-full text-white font-medium text-lg transition-all hover:scale-105 hover:shadow-2xl hover:shadow-green-500/30">
            <span>Explore Model</span>
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <button class="px-10 py-5 border border-white/15 rounded-full text-neutral-400 font-medium text-lg hover:bg-white/5 transition-colors">
            View Details
          </button>
        </div>

        <!-- Statistiques ou informations supplémentaires -->
        <div class="flex gap-12 pt-4 border-t border-white/5">
          <div>
            <span class="text-2xl font-black text-white">24k</span>
            <span class="block text-xs text-neutral-500 font-mono tracking-wider">Triangles</span>
          </div>
          <div>
            <span class="text-2xl font-black text-white">4K</span>
            <span class="block text-xs text-neutral-500 font-mono tracking-wider">Texture</span>
          </div>
          <div>
            <span class="text-2xl font-black text-white">60</span>
            <span class="block text-xs text-neutral-500 font-mono tracking-wider">FPS</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Indicateur de scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 pointer-events-none">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-600 font-mono">Scroll</span>
      <div class="w-[1px] h-10 bg-gradient-to-b from-neutral-600 to-transparent"></div>
    </div>
  </section>


<!-- Projects Section -->
<section class="relative w-full bg-gradient-to-b from-neutral-900 to-black py-24 md:py-32 overflow-hidden">
